{% doc %}
  @prompt
    Generate a Shopify Liquid section for the Stretch Theme with the following features:
    
    A video carousel to display UGC videos on the product page (PDP).
    
    Desktop view shows 5 videos at a time horizontally.
    
    Carousel has left and right scroll buttons to navigate.
    
    There are 10 total videos, only the middle video is autoplaying.
    
    Each video block should include a caption text below the video.
    
    Carousel should be responsive for mobile, showing fewer videos per row.
    
    Include settings in the section schema so the merchant can upload videos and captions in the theme editor.
    
    Ensure autoplay stops for non-visible videos and loops for the center video.
    
    Make the design clean and minimal so it works well on PDPs with other product info.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-carousel-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    position: relative;
  }

  .ai-video-carousel__container-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    padding: 0 60px;
  }

  .ai-video-carousel__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.video_gap }}px;
    transition: transform 0.5s ease;
    align-items: center;
  }

  .ai-video-carousel__item-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.desktop_videos_visible | minus: 1 }} * {{ block.settings.video_gap }}px)) / {{ block.settings.desktop_videos_visible }});
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .ai-video-carousel__item-{{ ai_gen_id }}.is-center {
    transform: scale({{ block.settings.center_video_scale }});
  }

  .ai-video-carousel__item-{{ ai_gen_id }}:not(.is-center) {
    opacity: {{ block.settings.side_video_opacity }};
  }

  .ai-video-carousel__video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.video_aspect_ratio }}%;
    background-color: {{ block.settings.video_background_color }};
    border-radius: {{ block.settings.video_border_radius }}px;
    overflow: hidden;
  }

  .ai-video-carousel__video-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-carousel__caption-{{ ai_gen_id }} {
    margin-top: {{ block.settings.caption_spacing }}px;
    text-align: {{ block.settings.caption_alignment }};
    color: {{ block.settings.caption_color }};
    font-size: {{ block.settings.caption_font_size }}px;
    line-height: 1.4;
  }

  .ai-video-carousel__nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_button_background }};
    color: {{ block.settings.nav_button_color }};
    border: none;
    width: {{ block.settings.nav_button_size }}px;
    height: {{ block.settings.nav_button_size }}px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: background-color 0.3s ease, transform 0.2s ease;
  }

  .ai-video-carousel__nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_button_hover_background }};
    transform: translateY(-50%) scale(1.1);
  }

  .ai-video-carousel__nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-video-carousel__nav-{{ ai_gen_id }}:disabled:hover {
    transform: translateY(-50%) scale(1);
  }

  .ai-video-carousel__nav--prev-{{ ai_gen_id }} {
    left: 0;
  }

  .ai-video-carousel__nav--next-{{ ai_gen_id }} {
    right: 0;
  }

  .ai-video-carousel__nav-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-video-carousel__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-video-carousel__placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .ai-video-carousel__container-{{ ai_gen_id }} {
      padding: 0 40px;
    }

    .ai-video-carousel__item-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.mobile_videos_visible | minus: 1 }} * {{ block.settings.video_gap }}px)) / {{ block.settings.mobile_videos_visible }});
    }

    .ai-video-carousel__nav-{{ ai_gen_id }} {
      width: {{ block.settings.nav_button_size | times: 0.8 }}px;
      height: {{ block.settings.nav_button_size | times: 0.8 }}px;
    }

    .ai-video-carousel__caption-{{ ai_gen_id }} {
      font-size: {{ block.settings.caption_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<video-carousel-{{ ai_gen_id }} class="ai-video-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-carousel__container-{{ ai_gen_id }}">
    <button
      class="ai-video-carousel__nav-{{ ai_gen_id }} ai-video-carousel__nav--prev-{{ ai_gen_id }}"
      aria-label="Previous videos"
      data-direction="prev"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <div class="ai-video-carousel__track-{{ ai_gen_id }}">
      {% for i in (1..10) %}
        {% liquid
          assign video_key = 'video_' | append: i
          assign caption_key = 'caption_' | append: i
          assign video = block.settings[video_key]
          assign caption = block.settings[caption_key]
        %}

        <div class="ai-video-carousel__item-{{ ai_gen_id }}" data-index="{{ forloop.index0 }}">
          <div class="ai-video-carousel__video-wrapper-{{ ai_gen_id }}">
            {% if video %}
              <video
                class="ai-video-carousel__video-{{ ai_gen_id }}"
                {% if forloop.index == 5 %}
                  autoplay
                {% endif %}
                loop
                muted
                playsinline
                preload="metadata"
              >
                {% for source in video.sources %}
                  <source src="{{ source.url }}" type="{{ source.mime_type }}">
                {% endfor %}
              </video>
            {% else %}
              <div class="ai-video-carousel__placeholder-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="23 7 16 12 23 17 23 7"></polygon>
                  <rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect>
                </svg>
              </div>
            {% endif %}
          </div>
          {% if caption != blank %}
            <div class="ai-video-carousel__caption-{{ ai_gen_id }}">{{ caption }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <button
      class="ai-video-carousel__nav-{{ ai_gen_id }} ai-video-carousel__nav--next-{{ ai_gen_id }}"
      aria-label="Next videos"
      data-direction="next"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
</video-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.totalVideos = 10;
        this.desktopVisible = {{ block.settings.desktop_videos_visible }};
        this.mobileVisible = {{ block.settings.mobile_videos_visible }};
        this.track = this.querySelector('.ai-video-carousel__track-{{ ai_gen_id }}');
        this.items = this.querySelectorAll('.ai-video-carousel__item-{{ ai_gen_id }}');
        this.videos = this.querySelectorAll('.ai-video-carousel__video-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('[data-direction="prev"]');
        this.nextButton = this.querySelector('[data-direction="next"]');
      }

      connectedCallback() {
        this.setupEventListeners();
        this.updateCarousel();
        this.updateVideoPlayback();
        
        window.addEventListener('resize', () => {
          this.updateCarousel();
        });
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.navigate('prev'));
        this.nextButton.addEventListener('click', () => this.navigate('next'));
      }

      navigate(direction) {
        const visibleCount = this.getVisibleCount();
        const maxIndex = this.totalVideos - visibleCount;

        if (direction === 'prev') {
          this.currentIndex = Math.max(0, this.currentIndex - 1);
        } else {
          this.currentIndex = Math.min(maxIndex, this.currentIndex + 1);
        }

        this.updateCarousel();
        this.updateVideoPlayback();
      }

      getVisibleCount() {
        return window.innerWidth <= 749 ? this.mobileVisible : this.desktopVisible;
      }

      updateCarousel() {
        const visibleCount = this.getVisibleCount();
        const itemWidth = this.items[0].offsetWidth;
        const gap = {{ block.settings.video_gap }};
        const offset = -(this.currentIndex * (itemWidth + gap));

        this.track.style.transform = `translateX(${offset}px)`;

        const centerIndex = this.currentIndex + Math.floor(visibleCount / 2);
        this.items.forEach((item, index) => {
          if (index === centerIndex) {
            item.classList.add('is-center');
          } else {
            item.classList.remove('is-center');
          }
        });

        const maxIndex = this.totalVideos - visibleCount;
        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex >= maxIndex;
      }

      updateVideoPlayback() {
        const visibleCount = this.getVisibleCount();
        const centerIndex = this.currentIndex + Math.floor(visibleCount / 2);

        this.videos.forEach((video, index) => {
          if (index === centerIndex) {
            video.play().catch(() => {});
          } else {
            video.pause();
          }
        });
      }
    }

    customElements.define('video-carousel-{{ ai_gen_id }}', VideoCarousel{{ ai_gen_id }});
  })();
</script>


{% doc %}
  @prompt
    create a slideshow with video block that has vimeo url to show video. use the same controler, headline, richtext, buttons feature as the Slideshow section.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-slideshow-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-video-slideshow__container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.slideshow_height_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-video-slideshow__container-{{ ai_gen_id }} {
      height: {{ block.settings.slideshow_height_desktop }}px;
    }
  }

  .ai-video-slideshow__slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.6s ease, visibility 0.6s ease;
  }

  .ai-video-slideshow__slide-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    z-index: 1;
  }

  .ai-video-slideshow__media-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .ai-video-slideshow__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-slideshow__video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    background-color: #000000;
  }

  .ai-video-slideshow__video-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    transform: translate(-50%, -50%);
  }

  .ai-video-slideshow__video-{{ ai_gen_id }} iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .ai-video-slideshow__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity }});
    z-index: 2;
  }

  .ai-video-slideshow__content-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.content_vertical_alignment }};
    align-items: {{ block.settings.content_horizontal_alignment }};
    padding: 40px 20px;
    z-index: 3;
    text-align: {% if block.settings.content_horizontal_alignment == 'flex-start' %}left{% elsif block.settings.content_horizontal_alignment == 'flex-end' %}right{% else %}center{% endif %};
  }

  @media screen and (min-width: 750px) {
    .ai-video-slideshow__content-{{ ai_gen_id }} {
      padding: 60px 40px;
    }
  }

  .ai-video-slideshow__subheading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .ai-video-slideshow__heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin: 0 0 20px;
    font-size: {{ block.settings.heading_size_mobile }}px;
    line-height: 1.1;
    max-width: 800px;
  }

  @media screen and (min-width: 750px) {
    .ai-video-slideshow__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_desktop }}px;
    }
  }

  .ai-video-slideshow__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin: 0 0 30px;
    font-size: {{ block.settings.text_size_mobile }}px;
    line-height: 1.6;
    max-width: 600px;
  }

  @media screen and (min-width: 750px) {
    .ai-video-slideshow__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_desktop }}px;
    }
  }

  .ai-video-slideshow__buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: {% if block.settings.content_horizontal_alignment == 'flex-start' %}flex-start{% elsif block.settings.content_horizontal_alignment == 'flex-end' %}flex-end{% else %}center{% endif %};
  }

  .ai-video-slideshow__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-size: {{ block.settings.button_font_size }}px;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ai-video-slideshow__button-{{ ai_gen_id }}--primary {
    background-color: {{ block.settings.primary_button_bg }};
    color: {{ block.settings.primary_button_text }};
    border: 2px solid {{ block.settings.primary_button_bg }};
  }

  .ai-video-slideshow__button-{{ ai_gen_id }}--primary:hover {
    background-color: {{ block.settings.primary_button_hover_bg }};
    border-color: {{ block.settings.primary_button_hover_bg }};
  }

  .ai-video-slideshow__button-{{ ai_gen_id }}--secondary {
    background-color: transparent;
    color: {{ block.settings.secondary_button_text }};
    border: 2px solid {{ block.settings.secondary_button_border }};
  }

  .ai-video-slideshow__button-{{ ai_gen_id }}--secondary:hover {
    background-color: {{ block.settings.secondary_button_hover_bg }};
    color: {{ block.settings.secondary_button_hover_text }};
    border-color: {{ block.settings.secondary_button_hover_bg }};
  }

  .ai-video-slideshow__controls-{{ ai_gen_id }} {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 12px;
    z-index: 4;
  }

  .ai-video-slideshow__dot-{{ ai_gen_id }} {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.5);
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .ai-video-slideshow__dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.text_color }};
    transform: scale(1.2);
  }

  .ai-video-slideshow__arrows-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    padding: 0 20px;
    z-index: 4;
    pointer-events: none;
  }

  .ai-video-slideshow__arrow-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.9);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    pointer-events: auto;
  }

  .ai-video-slideshow__arrow-{{ ai_gen_id }}:hover {
    background-color: rgba(255, 255, 255, 1);
    transform: scale(1.1);
  }

  .ai-video-slideshow__arrow-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    stroke: #000000;
  }

  .ai-video-slideshow__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-video-slideshow__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-video-slideshow__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }
{% endstyle %}

<video-slideshow-{{ ai_gen_id }}
  class="ai-video-slideshow-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-video-slideshow__container-{{ ai_gen_id }}">
    {% for i in (1..5) %}
      {% liquid
        assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
        assign slide_type_key = 'slide_' | append: i | append: '_type'
        assign slide_image_key = 'slide_' | append: i | append: '_image'
        assign slide_vimeo_key = 'slide_' | append: i | append: '_vimeo_url'
        assign slide_subheading_key = 'slide_' | append: i | append: '_subheading'
        assign slide_heading_key = 'slide_' | append: i | append: '_heading'
        assign slide_text_key = 'slide_' | append: i | append: '_text'
        assign slide_button1_text_key = 'slide_' | append: i | append: '_button1_text'
        assign slide_button1_link_key = 'slide_' | append: i | append: '_button1_link'
        assign slide_button2_text_key = 'slide_' | append: i | append: '_button2_text'
        assign slide_button2_link_key = 'slide_' | append: i | append: '_button2_link'

        assign slide_enabled = block.settings[slide_enabled_key]
        assign slide_type = block.settings[slide_type_key]
        assign slide_image = block.settings[slide_image_key]
        assign slide_vimeo = block.settings[slide_vimeo_key]
        assign slide_subheading = block.settings[slide_subheading_key]
        assign slide_heading = block.settings[slide_heading_key]
        assign slide_text = block.settings[slide_text_key]
        assign slide_button1_text = block.settings[slide_button1_text_key]
        assign slide_button1_link = block.settings[slide_button1_link_key]
        assign slide_button2_text = block.settings[slide_button2_text_key]
        assign slide_button2_link = block.settings[slide_button2_link_key]
      %}

      {% if slide_enabled %}
        <div
          class="ai-video-slideshow__slide-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
          data-slide-index="{{ forloop.index0 }}"
        >
          <div class="ai-video-slideshow__media-{{ ai_gen_id }}">
            {% if slide_type == 'image' %}
              {% if slide_image %}
                <img
                  src="{{ slide_image | image_url: width: 2000 }}"
                  alt="{{ slide_image.alt | escape }}"
                  loading="lazy"
                  width="{{ slide_image.width }}"
                  height="{{ slide_image.height }}"
                  class="ai-video-slideshow__image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-video-slideshow__placeholder-{{ ai_gen_id }}">
                  {{ 'hero-apparel-1' | placeholder_svg_tag }}
                  <div class="ai-video-slideshow__empty-state-{{ ai_gen_id }}">
                    Add an image for slide {{ i }}
                  </div>
                </div>
              {% endif %}
            {% elsif slide_type == 'video' %}
              <div class="ai-video-slideshow__video-wrapper-{{ ai_gen_id }}">
                {% if slide_vimeo != blank %}
                  <div
                    class="ai-video-slideshow__video-{{ ai_gen_id }}"
                    data-vimeo-url="{{ slide_vimeo }}"
                  ></div>
                {% else %}
                  <div class="ai-video-slideshow__placeholder-{{ ai_gen_id }}">
                    {{ 'hero-apparel-1' | placeholder_svg_tag }}
                    <div class="ai-video-slideshow__empty-state-{{ ai_gen_id }}">
                      Add a Vimeo URL for slide {{ i }}
                    </div>
                  </div>
                {% endif %}
              </div>
            {% endif %}
          </div>

          <div class="ai-video-slideshow__overlay-{{ ai_gen_id }}"></div>

          <div class="ai-video-slideshow__content-{{ ai_gen_id }}">
            {% if slide_subheading != blank %}
              <div class="ai-video-slideshow__subheading-{{ ai_gen_id }}">
                {{ slide_subheading }}
              </div>
            {% endif %}

            {% if slide_heading != blank %}
              <h2 class="ai-video-slideshow__heading-{{ ai_gen_id }}">
                {{ slide_heading }}
              </h2>
            {% endif %}

            {% if slide_text != blank %}
              <div class="ai-video-slideshow__text-{{ ai_gen_id }}">
                {{ slide_text }}
              </div>
            {% endif %}

            {% if slide_button1_text != blank or slide_button2_text != blank %}
              <div class="ai-video-slideshow__buttons-{{ ai_gen_id }}">
                {% if slide_button1_text != blank %}
                  <a
                    href="{{ slide_button1_link }}"
                    class="ai-video-slideshow__button-{{ ai_gen_id }} ai-video-slideshow__button-{{ ai_gen_id }}--primary"
                  >
                    {{ slide_button1_text }}
                  </a>
                {% endif %}

                {% if slide_button2_text != blank %}
                  <a
                    href="{{ slide_button2_link }}"
                    class="ai-video-slideshow__button-{{ ai_gen_id }} ai-video-slideshow__button-{{ ai_gen_id }}--secondary"
                  >
                    {{ slide_button2_text }}
                  </a>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if block.settings.show_arrows %}
    <div class="ai-video-slideshow__arrows-{{ ai_gen_id }}">
      <button
        class="ai-video-slideshow__arrow-{{ ai_gen_id }} ai-video-slideshow__arrow-prev-{{ ai_gen_id }}"
        aria-label="Previous slide"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button
        class="ai-video-slideshow__arrow-{{ ai_gen_id }} ai-video-slideshow__arrow-next-{{ ai_gen_id }}"
        aria-label="Next slide"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  {% endif %}

  {% if block.settings.show_dots %}
    <div class="ai-video-slideshow__controls-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
          assign slide_enabled = block.settings[slide_enabled_key]
        %}
        {% if slide_enabled %}
          <button
            class="ai-video-slideshow__dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
            data-slide-index="{{ forloop.index0 }}"
            aria-label="Go to slide {{ forloop.index }}"
          ></button>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</video-slideshow-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoSlideshow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.dots = [];
        this.autoplayInterval = null;
        this.vimeoPlayers = [];
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-video-slideshow__slide-{{ ai_gen_id }}'));
        this.dots = Array.from(this.querySelectorAll('.ai-video-slideshow__dot-{{ ai_gen_id }}'));
        this.prevButton = this.querySelector('.ai-video-slideshow__arrow-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-video-slideshow__arrow-next-{{ ai_gen_id }}');
        this.autoplay = this.dataset.autoplay === 'true';
        this.autoplaySpeed = parseInt(this.dataset.autoplaySpeed) * 1000;

        this.setupEventListeners();
        this.loadVimeoAPI();

        if (this.autoplay && this.slides.length > 1) {
          this.startAutoplay();
        }
      }

      setupEventListeners() {
        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            this.goToSlide(index);
            this.resetAutoplay();
          });
        });

        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => {
            this.previousSlide();
            this.resetAutoplay();
          });
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => {
            this.nextSlide();
            this.resetAutoplay();
          });
        }
      }

      loadVimeoAPI() {
        if (window.Vimeo) {
          this.initializeVimeoPlayers();
          return;
        }

        const script = document.createElement('script');
        script.src = 'https://player.vimeo.com/api/player.js';
        script.onload = () => {
          this.initializeVimeoPlayers();
        };
        document.head.appendChild(script);
      }

      initializeVimeoPlayers() {
        const videoElements = this.querySelectorAll('.ai-video-slideshow__video-{{ ai_gen_id }}[data-vimeo-url]');

        videoElements.forEach((element, index) => {
          const vimeoUrl = element.dataset.vimeoUrl;
          if (!vimeoUrl) return;

          const vimeoId = this.extractVimeoId(vimeoUrl);
          if (!vimeoId) return;

          const player = new Vimeo.Player(element, {
            id: vimeoId,
            background: true,
            muted: true,
            loop: true,
            autoplay: false,
            controls: false
          });

          this.vimeoPlayers.push({
            player: player,
            element: element
          });
        });
      }

      extractVimeoId(url) {
        const match = url.match(/vimeo\.com\/(\d+)/);
        return match ? match[1] : null;
      }

      goToSlide(index) {
        this.pauseAllVideos();

        this.slides[this.currentSlide].classList.remove('active');
        this.dots[this.currentSlide]?.classList.remove('active');

        this.currentSlide = index;

        this.slides[this.currentSlide].classList.add('active');
        this.dots[this.currentSlide]?.classList.add('active');

        this.playCurrentSlideVideo();
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      previousSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevIndex);
      }

      playCurrentSlideVideo() {
        const currentSlideElement = this.slides[this.currentSlide];
        const videoElement = currentSlideElement.querySelector('.ai-video-slideshow__video-{{ ai_gen_id }}');

        if (videoElement) {
          const playerObj = this.vimeoPlayers.find(p => p.element === videoElement);
          if (playerObj) {
            playerObj.player.play();
          }
        }
      }

      pauseAllVideos() {
        this.vimeoPlayers.forEach(playerObj => {
          playerObj.player.pause();
        });
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, this.autoplaySpeed);
      }

      resetAutoplay() {
        if (this.autoplay) {
          clearInterval(this.autoplayInterval);
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('video-slideshow-{{ ai_gen_id }}', VideoSlideshow{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Video slideshow",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "slideshow_height_mobile",
      "label": "Height on mobile",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "slideshow_height_desktop",
      "label": "Height on desktop",
      "min": 400,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "default": 700
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 0.8,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "header",
      "content": "Content position"
    },
    {
      "type": "select",
      "id": "content_vertical_alignment",
      "label": "Vertical alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "content_horizontal_alignment",
      "label": "Horizontal alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Text style"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size on mobile",
      "min": 24,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading size on desktop",
      "min": 32,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "label": "Text size on mobile",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "text_size_desktop",
      "label": "Text size on desktop",
      "min": 14,
      "max": 28,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 30
    },
    {
      "type": "color",
      "id": "primary_button_bg",
      "label": "Primary background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "primary_button_text",
      "label": "Primary text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "primary_button_hover_bg",
      "label": "Primary hover background",
      "default": "#f0f0f0"
    },
    {
      "type": "color",
      "id": "secondary_button_text",
      "label": "Secondary text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "secondary_button_border",
      "label": "Secondary border",

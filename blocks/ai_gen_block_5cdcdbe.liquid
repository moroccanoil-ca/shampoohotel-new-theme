{% doc %}
  @prompt
    Add autoplay functionality to a video carousel so that videos automatically play when they come into view. The autoplay should work for all videos in the carousel and should be muted by default to comply with browser autoplay policies., Can you make it show up to 10 videos instead of 5 ?
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-carousel-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    position: relative;
    overflow: hidden;
  }

  .ai-video-carousel__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-video-carousel__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-video-carousel__track-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-video-carousel__slide-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.slide_width }}%;
    scroll-snap-align: start;
    position: relative;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.video_background }};
  }

  .ai-video-carousel__video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.aspect_ratio }}%;
    background-color: {{ block.settings.video_background }};
  }

  .ai-video-carousel__video-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-carousel__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-video-carousel__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-video-carousel__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-video-carousel__controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: {{ block.settings.controls_spacing }}px;
  }

  .ai-video-carousel__button-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
  }

  .ai-video-carousel__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-video-carousel__button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-video-carousel__button-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-video-carousel__dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-video-carousel__dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.3;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.3s ease;
  }

  .ai-video-carousel__dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-video-carousel__slide-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.slide_width_mobile }}%;
    }
  }
{% endstyle %}

<video-carousel-{{ ai_gen_id }}
  class="ai-video-carousel-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-video-carousel__wrapper-{{ ai_gen_id }}">
    <div class="ai-video-carousel__track-{{ ai_gen_id }}" data-track>
      {% for i in (1..10) %}
        {% liquid
          assign video_key = 'video_' | append: i
          assign video = block.settings[video_key]
        %}

        <div class="ai-video-carousel__slide-{{ ai_gen_id }}" data-slide="{{ i }}">
          <div class="ai-video-carousel__video-wrapper-{{ ai_gen_id }}">
            {% if video %}
              <video
                class="ai-video-carousel__video-{{ ai_gen_id }}"
                data-video
                muted
                loop
                playsinline
                preload="metadata"
              >
                {% for source in video.sources %}
                  <source src="{{ source.url }}" type="{{ source.mime_type }}">
                {% endfor %}
              </video>
            {% else %}
              <div class="ai-video-carousel__placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
                {% if i == 1 %}
                  <div class="ai-video-carousel__empty-state-{{ ai_gen_id }}">
                    Next, add videos to the carousel
                  </div>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>

  {% if block.settings.show_controls %}
    <div class="ai-video-carousel__controls-{{ ai_gen_id }}">
      <button
        class="ai-video-carousel__button-{{ ai_gen_id }}"
        data-prev
        aria-label="Previous video"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="ai-video-carousel__dots-{{ ai_gen_id }}" data-dots></div>

      <button
        class="ai-video-carousel__button-{{ ai_gen_id }}"
        data-next
        aria-label="Next video"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  {% endif %}
</video-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = this.querySelector('[data-track]');
        this.slides = this.querySelectorAll('[data-slide]');
        this.videos = this.querySelectorAll('[data-video]');
        this.prevButton = this.querySelector('[data-prev]');
        this.nextButton = this.querySelector('[data-next]');
        this.dotsContainer = this.querySelector('[data-dots]');
        this.currentIndex = 0;
        this.observer = null;
      }

      connectedCallback() {
        this.setupDots();
        this.setupControls();
        this.setupIntersectionObserver();
        this.updateControls();
      }

      disconnectedCallback() {
        if (this.observer) {
          this.observer.disconnect();
        }
      }

      setupDots() {
        if (!this.dotsContainer) return;

        this.slides.forEach((slide, index) => {
          const dot = document.createElement('button');
          dot.className = 'ai-video-carousel__dot-{{ ai_gen_id }}';
          dot.setAttribute('aria-label', `Go to video ${index + 1}`);
          if (index === 0) dot.classList.add('active');
          
          dot.addEventListener('click', () => {
            this.goToSlide(index);
          });
          
          this.dotsContainer.appendChild(dot);
        });

        this.dots = this.querySelectorAll('.ai-video-carousel__dot-{{ ai_gen_id }}');
      }

      setupControls() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => {
            this.goToPrevious();
          });
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => {
            this.goToNext();
          });
        }

        this.track.addEventListener('scroll', () => {
          this.updateCurrentIndex();
        });
      }

      setupIntersectionObserver() {
        const options = {
          root: this.track,
          threshold: 0.5
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            const video = entry.target.querySelector('[data-video]');
            if (!video) return;

            if (entry.isIntersecting) {
              video.play().catch(() => {});
            } else {
              video.pause();
            }
          });
        }, options);

        this.slides.forEach((slide) => {
          this.observer.observe(slide);
        });
      }

      updateCurrentIndex() {
        const scrollLeft = this.track.scrollLeft;
        const slideWidth = this.slides[0].offsetWidth;
        const gap = parseInt('{{ block.settings.gap }}');
        
        this.currentIndex = Math.round(scrollLeft / (slideWidth + gap));
        this.updateDots();
        this.updateControls();
      }

      updateDots() {
        if (!this.dots) return;
        
        this.dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      updateControls() {
        if (this.prevButton) {
          this.prevButton.disabled = this.currentIndex === 0;
        }

        if (this.nextButton) {
          this.nextButton.disabled = this.currentIndex === this.slides.length - 1;
        }
      }

      goToSlide(index) {
        const slideWidth = this.slides[0].offsetWidth;
        const gap = parseInt('{{ block.settings.gap }}');
        const scrollPosition = index * (slideWidth + gap);
        
        this.track.scrollTo({
          left: scrollPosition,
          behavior: 'smooth'
        });
      }

      goToPrevious() {
        if (this.currentIndex > 0) {
          this.goToSlide(this.currentIndex - 1);
        }
      }

      goToNext() {
        if (this.currentIndex < this.slides.length - 1) {
          this.goToSlide(this.currentIndex + 1);
        }
      }
    }

    customElements.define('video-carousel-{{ ai_gen_id }}', VideoCarousel{{ ai_gen_id }});
  })();
</script>


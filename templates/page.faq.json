        "question_87ecLc": {
          "type": "question",
          "settings": {
            "question": "Where does ShampooHotel ship?",
            "answer": "<p>We ship anywhere within the United States via FedEx Standard Ground. Please note that additional charges apply for orders shipped to Alaska and Hawaii, <strong>and that we are unable to deliver to PO Boxes</strong>. At this time, we do not ship to Puerto Rico, Guam, the U.S. Virgin Islands, or other U.S. territories. Shipping to Canada and international destinations is also not available. For any questions or further assistance, feel free to reach out to our Client Care team at <a>support@shampoohotel.com</a>.<br/><br/></p>",
            "icon": "none",
            "icon_width": 24,
            "mobile_icon_width": 20
          }
        },
        "question_kdAJXy": {
          "type": "question",
          "settings": {
            "question": "What are your shipping costs?",
            "answer": "<p>We are happy to offer free shipping on all orders over $25. Shipping on orders less than $25 is a flat fee of $8.</p><p>Shipping to Alaska and Hawaii is a flat rate of $35.</p>",
            "icon": "none",
            "icon_width": 24,
            "mobile_icon_width": 20
          }
        },
        "question_M9zbWB": {
          "type": "question",
          "settings": {

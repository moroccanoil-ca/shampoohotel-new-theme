<style>
/* Reset all default modal styles for this specific popup */
.mo-image-popup.modal::part(base) {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.mo-image-popup.modal::part(overlay) {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(10px);
}

.mo-image-popup.modal::part(content) {
  position: relative;
  padding: 0;
  margin: 0;
  background: transparent;
  box-shadow: none;
  place-self: center;
  max-height: 90vh;
  max-width: 90vw;
}

.mo-image-popup.modal::part(body) {
  padding: 0;
  margin: 0;
  display: block;
  overflow: visible;
}

.mo-image-popup__wrapper {
  position: relative;
  display: block;
  max-height: 90vh;
  max-width: 90vw;
}

.mo-image-popup__wrapper picture {
  display: block;
}

.mo-image-popup__wrapper img {
  display: block;
  min-width: 60vw;
  height: auto;
  max-height: 90vh;
  object-fit: contain;
  border-radius: 8px;
}

.mo-image-popup.modal::part(close-button) {
  position: absolute;
  top: 1rem;
  right: 1rem;
  background: #F7F5E9;
  border-radius: 50%;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  cursor: pointer;
  border: none;
}

.mo-image-popup.modal::part(close-button):hover {
  background: #fff;
}

/* Desktop styles */
@media screen and (min-width: 1000px) {
  .mo-image-popup.modal::part(content) {
    min-width: 60vw;
  }
  
  .mo-image-popup__wrapper {
    min-width: 60vw;
    max-height: 85vh;
  }
  
  .mo-image-popup__wrapper img {
    max-height: 85vh;
  }
}

/* Mobile styles */
@media screen and (max-width: 999px) {
  .mo-image-popup.modal::part(content) {
    max-width: 85vw;
  }
  
  .mo-image-popup__wrapper {
    max-height: auto;
  }
  
  .mo-image-popup__wrapper img {
    width: 100vw;
  }
}
</style>

{%- unless request.page_type == 'captcha' -%}
  <image-popup 
    class="modal mo-image-popup" 
    apparition-delay="4" 
    title="Image popup" 
    handle-editor-events>
    
    {%- if section.settings.mobile_image != blank or section.settings.desktop_image != blank -%}
      <div class="mo-image-popup__wrapper">
        <picture>
          {%- if section.settings.mobile_image != blank -%}
            <source
              media="(max-width: 999px)"
              srcset="{{ section.settings.mobile_image | image_url: width: 400 }} 400w, {{ section.settings.mobile_image | image_url: width: 600 }} 600w, {{ section.settings.mobile_image | image_url: width: 800 }} 800w, {{ section.settings.mobile_image | image_url: width: 1000 }} 1000w, {{ section.settings.mobile_image | image_url: width: 1200 }} 1200w"
              width="{{ section.settings.mobile_image.width }}"
              height="{{ section.settings.mobile_image.height }}"
            >
          {%- endif -%}

          {%- assign desktop_img = section.settings.desktop_image | default: section.settings.mobile_image -%}
          {{- desktop_img | image_url: width: desktop_img.width | image_tag: loading: 'lazy', sizes: '(max-width: 999px) 85vw, 60vw', widths: '400,600,800,1000,1200,1400,1600,1800,2000,2400' -}}
        </picture>
      </div>
    {%- endif -%}
  </image-popup>
{%- endunless -%}

{% schema %}
{
  "name": "Image Popup",
  "class": "shopify-section--image-popup",
  "enabled_on": {
    "groups": ["custom.overlay"]
  },
  "limit": 1,
  "settings": [
    {
      "type": "paragraph",
      "content": "This popup will appear 4 seconds after page load and won't show again once closed."
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Image (Wide)",
      "info": "1800 x 1000px recommended for wide/landscape format"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image (Long)",
      "info": "1000 x 1600px recommended for tall/portrait format"
    }
  ],
  "presets": [
    {
      "name": "Image Popup"
    }
  ]
}
{% endschema %}
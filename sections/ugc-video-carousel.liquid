{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}

<section class="ai-ugc-carousel-{{ ai_gen_id }}" style="background-color: {{ section.settings.background_color }}; padding: 40px 20px;">
  {% if section.settings.heading != blank or section.settings.subheading != blank %}
    <div style="text-align: {{ section.settings.text_alignment }}; margin-bottom: 30px;">
      {% if section.settings.heading != blank %}
        <h2 style="font-size: {{ section.settings.heading_size }}px; color: {{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p style="font-size: {{ section.settings.subheading_size }}px; color: {{ section.settings.text_color }};">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div style="overflow:hidden; position:relative;">
    <div class="ai-ugc-carousel__track-{{ ai_gen_id }}" style="display:flex; gap: {{ section.settings.slide_gap }}px; transition: transform 0.5s ease;">
      {% for block in section.blocks %}
        {% assign video_url = block.settings.video | file_url %}
        <div style="flex:0 0 calc(100% / {{ section.settings.slides_desktop }} - {{ section.settings.slide_gap }}px * ({{ section.settings.slides_desktop }} - 1)/{{ section.settings.slides_desktop }}); display:flex; flex-direction:column; gap:16px;">
          <div style="position:relative; width:100%; height: {{ section.settings.video_height }}px; background:#000; border-radius: {{ section.settings.video_border_radius }}px; overflow:hidden;">
            {% if video_url %}
              <video src="{{ video_url }}" autoplay loop muted playsinline style="width:100%;height:100%;object-fit:cover;"></video>
              <button class="ai-ugc-play-btn" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:60px;height:60px;border-radius:50%;background:rgba(255,255,255,0.9);display:flex;align-items:center;justify-content:center;cursor:pointer;">▶</button>
              {% if block.settings.influencer_name != blank %}
                <div style="position:absolute;bottom:12px;left:12px;right:12px;background:rgba(0,0,0,0.7);color:#fff;padding:8px 12px;border-radius:8px;font-size:13px;">
                  {{ block.settings.influencer_name }}
                </div>
              {% endif %}
            {% else %}
              <div style="width:100%;height:100%;background:#f4f4f4;display:flex;align-items:center;justify-content:center;color:#999;">Upload a video</div>
            {% endif %}
          </div>

          {% if block.settings.product != blank %}
            <div style="background: {{ section.settings.product_card_bg }}; border-radius: {{ section.settings.product_border_radius }}px; padding:16px; display:flex; gap:12px; align-items:center;">
              <div style="width:80px;height:80px;overflow:hidden;flex-shrink:0;">
                {% if block.settings.product.featured_image %}
                  <img src="{{ block.settings.product.featured_image | image_url: width:160 }}" alt="{{ block.settings.product.title }}" style="width:100%;height:100%;object-fit:cover;">
                {% endif %}
              </div>
              <div style="flex:1; min-width:0;">
                <h3 style="font-size:14px;font-weight:600;color:{{ section.settings.text_color }};margin:0 0 4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ block.settings.product.title }}</h3>
                <div style="font-size:14px;color:{{ section.settings.text_color }}; margin-bottom:8px;">{{ block.settings.product.price | money }}</div>
                <a href="{{ block.settings.product.url }}" style="font-size:12px;color:{{ section.settings.link_color }};text-decoration:underline;">View product</a>
              </div>
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<script>
document.querySelectorAll('.ai-ugc-carousel-{{ ai_gen_id }}').forEach(carousel => {
  const videos = carousel.querySelectorAll('video');
  const playButtons = carousel.querySelectorAll('.ai-ugc-play-btn');

  playButtons.forEach((btn, idx) => {
    const video = videos[idx];
    btn.addEventListener('click', () => {
      video.play();
      btn.style.display='none';
    });
    video.addEventListener('pause', () => { btn.style.display='flex'; });
    video.addEventListener('ended', () => { btn.style.display='flex'; });
  });
});
</script>

{% schema %}
{
  "name": "UGC Video Carousel",
  "settings": [
    {"type":"text","id":"heading","label":"Heading","default":"Featured by influencers"},
    {"type":"text","id":"subheading","label":"Subheading","default":"See what our community loves"},
    {"type":"range","id":"slides_desktop","label":"Slides per view (desktop)","min":1,"max":4,"step":1,"default":3},
    {"type":"select","id":"slides_mobile","label":"Slides per view (mobile)","options":[{"value":"1","label":"1"},{"value":"2","label":"2"}],"default":"1"},
    {"type":"range","id":"slide_gap","label":"Gap between slides (px)","min":8,"max":40,"step":4,"default":16},
    {"type":"range","id":"video_height","label":"Video height (px)","min":300,"max":700,"step":50,"default":500},
    {"type":"checkbox","id":"show_arrows","label":"Show arrows","default":true},
    {"type":"checkbox","id":"show_dots","label":"Show dots","default":true},
    {"type":"color","id":"background_color","label":"Background color","default":"#f7f5e9"},
    {"type":"color","id":"heading_color","label":"Heading color","default":"#321e1e"},
    {"type":"color","id":"text_color","label":"Text color","default":"#321e1e"},
    {"type":"color","id":"product_card_bg","label":"Product card background","default":"#ffffff"},
    {"type":"color","id":"link_color","label":"Link color","default":"#321e1e"}
  ],
  "blocks":[
    {
      "type":"ugcvideo",
      "name":"UGC Video",
      "settings":[
        {"type":"video","id":"video","label":"Upload video"},
        {"type":"text","id":"influencer_name","label":"Influencer name"},
        {"type":"product","id":"product","label":"Featured product"}
      ]
    }
  ],
  "presets":[{"name":"UGC Video Carousel"}]
}
{% endschema %}
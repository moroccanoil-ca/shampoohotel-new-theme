<style>
  .image-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.8);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .image-modal.active {
    display: flex;
  }

  .image-modal__content {
    position: relative;
    width: 60vw;
    max-width: 1400px;
    max-height: 70vh;
  }

  .image-modal__media {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 60vh;
    max-height: 60vh;
  }

  .image-modal__media .content-box__background-media {
    width: 100%;
    height: 100%;
  }

  .image-modal__media img,
  .image-modal__media picture {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-modal__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .image-modal__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: {{ section.settings.text_color }};
    border: none;
    color: {{ section.settings.overlay_color }};
    font-size: 2rem;
    cursor: pointer;
    z-index: 10;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Mobile adjustments */
  @media (max-width: 768px) {
    .image-modal__content {
      width: 90vw;
      height: auto;
      max-height: none;
    }

    .image-modal__media {
      min-height: 50vh;
      max-height: none;
    }

    .image-modal {
      padding: 1rem;
    }
  }
</style>

{%- if section.settings.show_modal -%}
  <div class="image-modal {% if section.settings.color_scheme != blank %}color-scheme color-scheme--{{ section.settings.color_scheme.id }}{% endif %}"
       id="image-modal-{{ section.id }}" 
       data-modal>
    <div class="image-modal__content">
<button class="image-modal__close" type="button" aria-label="{{ 'general.accessibility.close' | t }}">
        ×
      </button>
      
      <div class="image-modal__media">
        {%- if section.settings.desktop_image != blank or section.settings.mobile_image != blank -%}
          <div class="content-box__background-media with-overlay" 
               style="--overlay: {{ section.settings.overlay_color.rgb }} / {{ section.settings.overlay_opacity | divided_by: 100.0 }}">
            {%- liquid
              if section.settings.desktop_image != blank
                render 'media' with section.settings.desktop_image, mobile_media: section.settings.mobile_image, preload: false
              else
                echo 'lifestyle-1' | placeholder_svg_tag: 'size-full'
              endif
            -%}
          </div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          {%- assign text_alignment = section.settings.text_position | split: '-' | last -%}
          
          <div class="image-modal__overlay {{ section.settings.text_position }}">
            <div class="max-w-{{ section.settings.content_width }} prose prose-justify-{{ text_alignment }}">
              {%- for block in section.blocks -%}
                {%- case block.type -%}
                  {%- when 'heading' -%}
                    {%- render 'heading', 
                      content: block.settings.text,
                      html_tag: block.settings.html_tag,
                      style: block.settings.heading_size,
                      block: block
                    -%}
                  
                  {%- when 'rich_text' -%}
                    {%- if block.settings.text != blank -%}
                      <div class="{% if block.settings.content_width != 'full' %}max-w-{{ block.settings.content_width }}{% endif %}" {{ block.shopify_attributes }}>
                        {{- block.settings.text -}}
                      </div>
                    {%- endif -%}
                  
                  {%- when 'button' -%}
                    {%- render 'button', 
                      content: block.settings.text,
                      href: block.settings.url,
                      size: block.settings.size,
                      style: block.settings.style,
                      block: block
                    -%}
                {%- endcase -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  <script>
    console.log('[Modal Debug] Script loaded');
    console.log('[Modal Debug] auto_show setting value:', {{ section.settings.auto_show }});
    console.log('[Modal Debug] show_only_once setting value:', {{ section.settings.show_only_once }});
    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initModal);
    } else {
      initModal();
    }

    function initModal() {
      console.log('[Modal Debug] initModal called');
      
      const modal = document.getElementById('image-modal-{{ section.id }}');
      console.log('[Modal Debug] Modal element:', modal);
      
      if (!modal) {
        console.error('[Modal Debug] Modal element not found!');
        return;
      }
      
      const closeBtn = modal.querySelector('.image-modal__close');
      const storageKey = 'theme:image-modal-{{ section.id }}';
      
      console.log('[Modal Debug] Storage key:', storageKey);
      console.log('[Modal Debug] Current storage value:', localStorage.getItem(storageKey));
      console.log('[Modal Debug] About to check auto_show...');
      
      // Check if modal should show
      function shouldShowModal() {
        // Always show in theme editor
        if (window.Shopify && window.Shopify.designMode) {
          console.log('[Modal Debug] In design mode - should show');
          return true;
        }
        
        // Check if show_only_once is enabled and modal was already shown
        {%- if section.settings.show_only_once -%}
          const canShow = localStorage.getItem(storageKey) !== 'true';
          console.log('[Modal Debug] show_only_once enabled, canShow:', canShow);
          return canShow;
        {%- else -%}
          console.log('[Modal Debug] show_only_once disabled - always show');
          return true;
        {%- endif -%}
      }
      
      // Auto-show modal on page load if enabled
      {%- if section.settings.auto_show -%}
        console.log('[Modal Debug] auto_show is ENABLED');
        const shouldDisplay = shouldShowModal();
        console.log('[Modal Debug] shouldShowModal returned:', shouldDisplay);
        
        if (shouldDisplay) {
          const delay = {{ section.settings.delay | times: 1000 }};
          console.log('[Modal Debug] Setting timeout for', delay, 'ms');
          
          setTimeout(() => {
            console.log('[Modal Debug] Timeout fired - adding active class');
            modal.classList.add('active');
            
            // Mark as shown
            {%- if section.settings.show_only_once -%}
              localStorage.setItem(storageKey, 'true');
              console.log('[Modal Debug] Marked as shown in localStorage');
            {%- endif -%}
          }, delay);
        } else {
          console.log('[Modal Debug] Modal already shown - skipping');
        }
      {%- else -%}
        console.log('[Modal Debug] auto_show is DISABLED');
      {%- endif -%}

      // Close modal on button click
      closeBtn.addEventListener('click', () => {
        modal.classList.remove('active');
        {%- if section.settings.show_only_once -%}
          localStorage.setItem(storageKey, 'true');
        {%- endif -%}
      });

      // Close modal on background click
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          modal.classList.remove('active');
          {%- if section.settings.show_only_once -%}
            localStorage.setItem(storageKey, 'true');
          {%- endif -%}
        }
      });

      // Close modal on ESC key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal.classList.contains('active')) {
          modal.classList.remove('active');
          {%- if section.settings.show_only_once -%}
            localStorage.setItem(storageKey, 'true');
          {%- endif -%}
        }
      });

      // Optional: Trigger modal with custom button
      window.openImageModal = () => {
        modal.classList.add('active');
      };
    }
  </script>
{%- endif -%}

{% schema %}
